# =====================================================================
# NSE Insights — example environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# =====================================================================

# ---- FRONTEND ----
# These are baked into supabase-client.js / pricing.html via
# window.NSE_CONFIG. They are public values (anon key is safe to expose).
SUPABASE_URL=https://xxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
PAYMENTS_API=https://payments.nseinsights.co.ke

# ---- BACKEND (payments_server.py) ----

# Frontend URL used for redirect URLs in Stripe Checkout
FRONTEND_URL=https://nseinsights.co.ke

# Stripe — create at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs — one per plan & interval
# Create these in the Products section of the Stripe dashboard.
STRIPE_PRICE_TRADER_MO=price_xxxxxxxxxxxx
STRIPE_PRICE_TRADER_YR=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_MO=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_YR=price_xxxxxxxxxxxx

# Safaricom Daraja (M-Pesa) — https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://payments.nseinsights.co.ke/api/mpesa/callback
MPESA_ENV=sandbox
# For production: MPESA_ENV=production

# Supabase service role key (server-side ONLY — never ship to the browser)
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# ---- Feedback (optional) ----
# Where user-submitted feedback emails are delivered. Defaults to feedback@nseinsights.co.ke.
FEEDBACK_EMAIL_TO=feedback@nseinsights.co.ke

# SMTP relay for sending feedback emails. If any of these are blank,
# feedback is only logged to stdout + (if configured) a Supabase `feedback` table.
# For Gmail App Passwords: host=smtp.gmail.com port=587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# The mailto: fallback in the browser uses FEEDBACK_EMAIL_TO — set
# window.NSE_CONFIG.FEEDBACK_EMAIL in index.html if you need a different address.

# Comma-separated allowed origins for the payments API.
# Tighten this in production. Example:
#   CORS_ORIGINS=https://nseinsights.co.ke,https://nse-insights.pages.dev
# Leave empty in dev to allow all origins.
CORS_ORIGINS=
