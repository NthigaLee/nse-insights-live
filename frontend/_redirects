# Cloudflare Pages — redirects + rewrites.
# Pages automatically strips .html extensions (e.g. /login.html → /login)
# and serves the content of foo.html at /foo. So we only need rules for paths
# that Pages can't infer (like / → landing, or /signup → /login alias).

# Root → marketing landing (200 = internal rewrite, URL stays /)
/                   /landing.html             200

# Short aliases (301 = browser navigates)
/home               /                         301
/signup             /login                    301
/signin             /login                    301
/dashboard          /index                    301

# Multi-word paths Pages won't auto-resolve
/checkout/success   /checkout-success.html    200
/checkout/cancel    /checkout-cancel.html     200
/admin/financials   /admin_financials.html    200
/admin/review       /admin_review.html        200
